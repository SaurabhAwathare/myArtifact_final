rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- HELPER FUNCTIONS ---
    function isAuth() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuth() && request.auth.uid == userId;
    }

    // Business Purpose: Determine if user has global administrative rights.
    // Security Purpose: Prevents non-admins from accessing moderation tools.
    // Protected by: admin_rules.test.js
    function isGlobalAdmin() {
      return isAuth() &&
             exists(/databases/$(database)/documents/users/$(request.auth.uid)/private/settings) &&
             (get(/databases/$(database)/documents/users/$(request.auth.uid)/private/settings).data.isAdmin == true);
    }

    function getIdentityMetadata(data) {
      return data.get('identityMetadata', {});
    }

    // Invariant: Identity versions must be monotonic and consistent.
    function isValidIdentityUpdate(oldData, newData) {
      let oldMeta = getIdentityMetadata(oldData);
      let newMeta = getIdentityMetadata(newData);
      return newMeta.get('identityResetVersion', 0) >= oldMeta.get('identityResetVersion', 0) &&
             newMeta.get('lastCompletedIdentityVersion', 0) >= oldMeta.get('lastCompletedIdentityVersion', 0) &&
             newMeta.get('lastCompletedIdentityVersion', 0) <= newMeta.get('identityResetVersion', 0) &&
             newMeta.get('emergencyResetCount', 0) >= oldMeta.get('emergencyResetCount', 0);
    }

    // --- USERS & PROFILES ---
    match /users/{uid} {
      // Business Purpose: Allow public profile access but hide sensitive PII.
      // Security Purpose: Prevents exposure of email and real name.
      allow read: if isOwner(uid) ||
                   (isAuth() && !resource.data.keys().hasAny(['email', 'displayName', 'realName', 'fcmToken']));

      // Business Purpose: Securely update user profiles including identity reset state.
      // Security Purpose: Prevents self-promotion and ensures identity metadata integrity.
      // Protected by: admin_rules.test.js, identity_reset_rules.test.js
      allow update: if isOwner(uid) &&
                   !(request.resource.data.diff(resource.data).affectedKeys()
                     .hasAny(['isAdmin', 'admin', 'accountStatus', 'email', 'realName'])) &&
                   isValidIdentityUpdate(resource.data, request.resource.data);

      // Business Purpose: Create initial user profile.
      // Security Purpose: Prevents setting privileged fields during account creation.
      // Protected by: admin_rules.test.js
      allow create: if isOwner(uid) &&
                    !("isAdmin" in request.resource.data) &&
                    !("admin" in request.resource.data) &&
                    !("accountStatus" in request.resource.data);

      match /private/settings {
        // Protected by: admin_rules.test.js
        allow read: if isOwner(uid) || isGlobalAdmin();

        allow create: if isOwner(uid) &&
                      request.resource.data.get('isAdmin', false) == false &&
                      request.resource.data.get('admin', false) == false &&
                      request.resource.data.get('accountStatus', 'ACTIVE') == 'ACTIVE';

        allow update: if isOwner(uid) &&
                     !(request.resource.data.diff(resource.data).affectedKeys()
                       .hasAny(['isAdmin', 'admin', 'accountStatus']));

        allow write: if isGlobalAdmin();
      }

      // Resonance & Engagement
      // Zero-Trust: Clients can only READ relationships, never WRITE.
      // Backend (Cloud Functions) handles all writes to resonance_in/out.
      match /resonance_in/{targetId} { allow read: if isAuth(); allow write: if false; }
      match /resonance_out/{targetId} { allow read: if isAuth(); allow write: if false; }
      match /followers/{targetId} { allow read: if isAuth(); allow write: if false; }
      match /following/{targetId} { allow read: if isAuth(); allow write: if false; }

      // NEW: Interaction Intents (Zero-Trust)
      match /private/intents/follow/{targetId} {
        allow read, write: if isOwner(uid);
      }

      // Business Purpose: Track playback progress and unlock status.
      // Security Purpose: Prevents client from self-unlocking comments.
      // Protected by: engagement_rules.test.js
      match /engagement/{id} {
        allow read: if isOwner(uid);
        allow create: if isOwner(uid) &&
                      !("isCommentUnlocked" in request.resource.data) &&
                      !("engagementState" in request.resource.data);
        allow update: if isOwner(uid) &&
                     !(request.resource.data.diff(resource.data).affectedKeys()
                       .hasAny(['isCommentUnlocked', 'engagementState']));
      }

      match /private/interactions/reactions/{artifactId} {
        allow read, write: if isOwner(uid);
      }

      // Intent for Reactions (to trigger notifications/aggregates)
      match /private/intents/reactions/{artifactId} {
        allow read, write: if isOwner(uid);
      }

      match /savedArtifacts/{artifactId} {
        allow read, write: if isOwner(uid);
      }

      match /private/published_artifacts/artifacts/{artifactId} {
        allow read, write: if isOwner(uid);
      }
    }

    // --- ARTIFACTS (The Hearth) ---
    match /artifacts/{artifactId} {
      allow read: if resource == null ||
                   (resource.data.get('isPublic', false) == true) ||
                   isOwner(resource.data.userId) ||
                   isGlobalAdmin();

      // Fix Identity Spoofing: Ensure userId matches current user and anonymousId is verified
      allow create: if isAuth() &&
                    request.resource.data.userId == request.auth.uid &&
                    request.resource.data.author.anonymousId == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.anonymousId &&
                    request.resource.data.author.keys().hasAll(['anonymousId', 'name']);

      // Secured updates: Allow owner full control.
      // Zero-Trust: Clients cannot increment commentCount. Aggregates are server-owned.
      allow update: if isGlobalAdmin() || isOwner(resource.data.userId);

      allow delete: if isGlobalAdmin() || isOwner(resource.data.userId);

      match /stats/resonance {
        allow read: if true;
        allow write: if false;
      }
    }

    // --- COMMENTS (The Intimacy Layers) ---
    match /comments/{commentId} {
      allow read: if isAuth() && (
        resource.data.authorId == request.auth.uid ||
        (resource.data.artifactOwnerId == request.auth.uid && resource.data.visibilityLayer != 'SANCTUARY') ||
        (resource.data.visibilityLayer == 'RESONANCE' && resource.data.moderationState == 'APPROVED' && (resource.data.revealAt == null || resource.data.revealAt <= request.time))
      );

      // MIGRATION: Comments now validated against the private engagement subcollection and trusted artifact ownership
      allow create: if isAuth() &&
                    request.resource.data.authorId == request.auth.uid &&
                    request.resource.data.artifactOwnerId == get(/databases/$(database)/documents/artifacts/$(request.resource.data.artifactId)).data.userId &&
                    (
                      request.resource.data.artifactOwnerId == request.auth.uid ||
                      get(/databases/$(database)/documents/users/$(request.auth.uid)/engagement/$(request.resource.data.artifactId)).data.isCommentUnlocked == true
                    );

      allow update: if (isOwner(resource.data.authorId) &&
                    !(request.resource.data.diff(resource.data).affectedKeys()
                      .hasAny(['authorId', 'artifactId', 'artifactOwnerId']))) ||
                    (isOwner(resource.data.artifactOwnerId) &&
                     request.resource.data.diff(resource.data).affectedKeys().hasOnly(['creatorReaction'])) ||
                    isGlobalAdmin();

      allow delete: if isOwner(resource.data.authorId) ||
                    isOwner(resource.data.artifactOwnerId) ||
                    isGlobalAdmin();
    }

    match /artifact_reaction_counts/{artifactId} {
      allow read: if true;
      allow write: if false;
    }

    // --- IDENTITY & ANTI-ENUMERATION ---
    match /usernames/{id} {
      allow read: if isAuth();
      allow create: if isAuth() && request.resource.data.uid == request.auth.uid;
      allow update: if isAuth() && resource.data.uid == request.auth.uid && request.resource.data.uid == request.auth.uid;
      allow delete: if isAuth() && (resource == null || resource.data.uid == request.auth.uid);
    }

    // --- CONSOLIDATED REACTIONS ---
    match /artifact_reactions/{id} {
      allow read: if isAuth() && (
        resource.data.userId == request.auth.uid ||
        resource.data.artifactOwnerId == request.auth.uid
      );
      // Zero-Trust: Clients can only READ global reactions. Writes handled by Backend.
      allow write: if false;
    }

    // --- NOTIFICATIONS & REPORTS ---
    match /notifications/{id} {
      // Only readable by the target user
      allow read: if isAuth() && request.auth.uid == resource.data.userId;
      // Users can only delete their own notifications
      allow delete: if isAuth() && request.auth.uid == resource.data.userId;

      // Allow recipient to update only isRead
      allow update: if isAuth() && request.auth.uid == resource.data.userId &&
                    request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isRead']);

      // Zero-Trust: Clients can NO LONGER create notifications directly.
      // Must be authored by Backend (Cloud Functions).
      allow create: if false;
    }

    match /reports/{id} {
      allow create: if isAuth() && request.resource.data.reporterId == request.auth.uid;
      allow read, write: if isGlobalAdmin();
    }


    // DEPRECATED: Points to legacy listening_sessions.
    // To be removed once Engagement subcollection migration is verified.
    match /listening_sessions/{sessionId} {
      allow read, write: if isAuth() && (resource == null || resource.data.userId == request.auth.uid);
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
    }

    match /recommendation_profiles/{uid} {
      allow read: if isOwner(uid);
    }
  }
}
