rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- HELPER FUNCTIONS ---
    function isAuth() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuth() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuth() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)/private/settings).data.isAdmin == true;
    }

    // --- USERS & PROFILES ---
    match /users/{uid} {
      allow read: if isOwner(uid) ||
                   (isAuth() && !resource.data.keys().hasAny(['email', 'displayName', 'realName']));

      allow write: if isOwner(uid) &&
                   !(request.resource.data.diff(resource.data).affectedKeys().hasAny(['isAdmin', 'accountStatus', 'email', 'realName']));

      match /private/settings {
        allow read: if isOwner(uid) || isAdmin();
        allow write: if isOwner(uid) &&
                     !(request.resource.data.diff(resource.data).affectedKeys().hasAny(['isAdmin', 'accountStatus']));
        allow write: if isAdmin();
      }

      // Private Interaction State (The Pulse)
      match /private/interactions/reactions/{artifactId} {
        allow read, write: if isOwner(uid);
      }

      match /savedArtifacts/{artifactId} {
        allow read, write: if isOwner(uid);
      }

      // Ownership mapping for artifacts (Private)
      match /private/published_artifacts/artifacts/{artifactId} {
        allow read, write: if isOwner(uid);
      }
    }

    // --- ARTIFACTS (The Hearth) ---
    match /artifacts/{artifactId} {
      // Ensure only sanitized artifacts (using AuthorSnapshot) are publicly readable
      allow read: if (resource.data.isPublic == true && resource.data.keys().hasAll(['author'])) ||
                   isOwner(resource.data.userId) ||
                   isAdmin();

      // Create: Enforce author snapshot integrity and no direct UID exposure if possible
      allow create: if isAuth() &&
                    request.resource.data.author.keys().hasAll(['anonymousId', 'name']);

      allow update, delete: if isAdmin() || isOwner(resource.data.userId);

      // Aggregate Resonance (The Echo)
      match /stats/resonance {
        allow read: if true;
        allow write: if false; // Only Cloud Functions
      }
    }

    // --- REFLECTIONS (The Intimacy Layers) ---
    match /comments/{commentId} {
      allow read: if isAuth() && (
        // 1. Author Access (Sanctuary)
        resource.data.authorId == request.auth.uid ||

        // 2. Artifact Owner Access (Bridge)
        // Note: Using cached artifactOwnerId for performance and reliability
        resource.data.artifactOwnerId == request.auth.uid ||

        // 3. Public Resonance (After Reveal)
        (resource.data.visibilityLayer == 'RESONANCE' &&
         resource.data.moderationState == 'APPROVED' &&
         (resource.data.revealAt == null || resource.data.revealAt <= request.time))
      );

      allow create: if isAuth() && request.resource.data.authorId == request.auth.uid;

      // Owners can delete any comment on their artifact
      allow delete: if isAuth() && (
        resource.data.authorId == request.auth.uid ||
        resource.data.artifactOwnerId == request.auth.uid ||
        isAdmin()
      );
    }

    // --- REACTION COUNTS (Legacy Support & Aggregates) ---
    match /artifact_reaction_counts/{artifactId} {
      allow read: if true;
      allow write: if false; // Only Cloud Functions or Admin
    }

    // --- IDENTITY & ANTI-ENUMERATION ---
    match /usernames/{id} {
      // Prevent enumeration: only allow existence check via specific document read if authenticated
      allow read: if isAuth();
      allow create: if isAuth() && request.resource.data.uid == request.auth.uid;
      allow delete: if isAuth() && resource.data.uid == request.auth.uid;
    }

    // --- GLOBAL REACTIONS (DEPRECATED for Second-Order Privacy) ---
    match /reactions_global/{id} {
      // Only readable by the owner or the artifact owner
      allow read: if isAuth() && (
        resource.data.userId == request.auth.uid ||
        resource.data.artifactOwnerId == request.auth.uid
      );
      allow write: if isAuth() && request.resource.data.userId == request.auth.uid;
      allow delete: if isAuth() && (
        resource.data.userId == request.auth.uid ||
        resource.data.artifactOwnerId == request.auth.uid
      );
    }

    // --- OTHER COLLECTIONS ---
    match /notifications/{id} {
      allow read, write: if isAuth() && request.auth.uid == resource.data.userId;
      allow create: if isAuth();
    }

    match /reports/{id} {
      allow create: if isAuth();
      allow read, write: if isAdmin();
    }

    // --- LISTENING SESSIONS ---
    match /listening_sessions/{sessionId} {
      allow read, write: if isAuth() && request.auth.uid == resource.data.userId;
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
    }
  }
}

