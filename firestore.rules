rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // User profiles
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isOwner(userId);
    }

    // Artifacts
    match /artifacts/{artifactId} {
      allow read: if isAuthenticated(); // Could be more restrictive for private artifacts
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isOwner(resource.data.userId);

      // Replies sub-collection
      match /replies/{replyId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated();
        allow delete: if isAuthenticated() && (isOwner(resource.data.userId) || isOwner(get(/databases/$(database)/documents/artifacts/$(artifactId)).data.userId));
      }
    }

    // Reactions
    match /reactions/{reactionId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && request.auth.uid == request.resource.data.userId;
      allow delete: if isAuthenticated() && request.auth.uid == resource.data.userId;
    }

    // Global Reactions (for profile liked tab)
    match /reactions_global/{reactionId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && request.auth.uid == request.resource.data.userId;
      allow delete: if isAuthenticated() && request.auth.uid == resource.data.userId;
    }

    // Private Feedback
    match /feedback_private/{feedbackId} {
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow read, update, delete: if false; // Only accessible via Admin SDK/Cloud Functions
    }

    // Reports
    match /reports/{reportId} {
      allow create: if isAuthenticated(); // Device hash is handled client-side
      allow read, update, delete: if false; // Only accessible via Admin SDK/Moderation tools
    }

    // Notifications
    match /notifications/{notificationId} {
      allow read, update: if isOwner(resource.data.userId);
      allow delete: if isOwner(resource.data.userId);
      allow create: if false; // Only created via Cloud Functions
    }
  }
}
